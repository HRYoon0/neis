{
  "manifest_version": 3,
  "name": "NEIS 종합의견 자동입력 도우미",
  "version": "1.0.1",
  "description": "엑셀·CSV 파일의 내용을 나이스 학기말종합의견·행동특성및종합의견·창의적체험활동 화면에 번호·이름으로 자동 입력합니다.",
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": [
    "https://*.neis.go.kr/*",
    "https://*.eduptl.kr/*",
    "https://*.edunavi.kr/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "NEIS 자동입력 도우미 열기"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.neis.go.kr/*",
        "https://*.eduptl.kr/*",
        "https://*.edunavi.kr/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
